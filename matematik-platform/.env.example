# Supabase Configuration
# Gerçek değerleri buraya YAZMAYIN — .env.local kullanın (./scripts/bootstrap-env.sh)
# GitHub Actions: aynı iki değişkeni Repository Secrets olarak ekleyin (docs/GITHUB_CI.md).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Sohbet: admin TC (sağda mavi baloncuk); örn. Uğur Hoca hesabının TC'si
NEXT_PUBLIC_CHAT_ADMIN_TC=

# Required for import scripts + /api/chat-register (sohbet girişi). Server-only; Vercel'e ekleyin.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Yaprak test adayı arama kaynakları.
# Virgülle ayrılmış izinli sayfa veya PDF URL listesi girin.
WORKSHEET_CANDIDATE_SOURCE_URLS=
WORKSHEET_CANDIDATE_ALLOWED_HOSTS=

# Vercel Cron endpoint'leri için server-only gizli anahtar.
CRON_SECRET=change-this-cron-secret

# Google Drive OAuth (admin PDF kopyalama paketleri için)
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/admin-google-drive/callback

# E-posta bildirimleri (Resend)
RESEND_API_KEY=your_resend_api_key_here

# Admin e-postaları (virgülle ayrılmış)
ADMIN_EMAILS=admin@ugurhoca.com
